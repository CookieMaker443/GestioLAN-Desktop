# ----------------------------------------------------------------------
# 1. Maven Build Artifacts (Devono essere ignorati ovunque)
# ----------------------------------------------------------------------
# IGNORA LE CARTELLE TARGET IN TUTTI I SOTTO-MODULI (shared, desktop, ecc.)
**/target/
target/

GEMINI.md
LLM_output/

# Ignora i log e i report di test di Maven in qualsiasi modulo
**/target/surefire-reports/*
**/target/failsafe-reports/*
test-output/

# ----------------------------------------------------------------------
# 2. Artifacts del Sistema Operativo e IDE
# ----------------------------------------------------------------------
# macOS
.DS_Store

# File di configurazione di IDE comuni (IntelliJ IDEA)
.idea/
*.iml
*.iws
*.ipr

# File di configurazione di VS Code
.vscode/

# ----------------------------------------------------------------------
# 3. File Java Specifici
# ----------------------------------------------------------------------
# File di classe compilati
*.class

# File di output della JVM
*.log
hs_err_pid*

# ----------------------------------------------------------------------
# 4. File Utili per Maven (se generati fuori da target/)
# ----------------------------------------------------------------------
dependency-reduced-pom.xml

# ----------------------------------------------------------------------
# 5. File di risorse assets (Aggiornato per struttura multi-modulo)
# ----------------------------------------------------------------------
# Il prefisso **/ permette di intercettare le immagini anche se ora sono dentro "desktop/"
**/src/main/resources/assets/images/*.png
**/src/main/resources/assets/images/*.jpeg
**/src/main/resources/assets/images/*.svg
**/src/main/resources/assets/images/*.xcf

**/src/main/resources/assets/images/svgs/*.png
**/src/main/resources/assets/images/svgs/*.jpeg
**/src/main/resources/assets/images/svgs/*.svg
**/src/main/resources/assets/images/svgs/*.xcf
.fake

# ----------------------------------------------------------------------
# 6. Predisposizione per Android Studio (Gradle)
# ----------------------------------------------------------------------
.gradle/
**/build/
local.properties
.navigation/
captures/
*.apk
*.aar